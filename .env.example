# Один файл: скопируйте в .env и заполните секреты.
# Используется и локально (load_dotenv), и в docker compose (env_file для db/web + монтирование в контейнер).
# В docker compose сервис web с network_mode: host задаёт в окружении POSTGRES/REDIS на 127.0.0.1
# и DJANGO_DOCKER_HOST_NETWORK=true (см. docker-compose.yml). Локально без Docker подмена localhost→db/redis
# в classroom/settings.py включается только внутри контейнера без этого флага.

DJANGO_SECRET_KEY=django-insecure-dev-key-change-me
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=*

# Логи: вход через Яндекс — логгер classroom.yandex_oauth (по умолчанию DEBUG при DJANGO_DEBUG).
# DJANGO_YANDEX_OAUTH_LOG_LEVEL=DEBUG
# DJANGO_ALLAUTH_LOG_LEVEL=WARNING
# DJANGO_LOG_LEVEL=INFO

# Формы / OAuth за нестандартным хостом или портом (через запятую):
# DJANGO_CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000

# django.contrib.sites (pk=1): после migrate entrypoint обновит домен, если задано:
# DJANGO_SITE_DOMAIN=127.0.0.1:8000
# DJANGO_SITE_NAME=Classroom

# PostgreSQL: для docker compose оставьте localhost — внутри контейнера web хост станет db.
POSTGRES_DB=classroom
POSTGRES_USER=classroom
POSTGRES_PASSWORD=classroom
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

REDIS_URL=redis://127.0.0.1:6379/0
REDIS_CACHE_URL=redis://127.0.0.1:6379/1
# Только если Redis недоступен (не рекомендуется): in-memory каналы + LocMemCache
# CHANNEL_LAYER_IN_MEMORY=true

# По умолчанию в коде: PostgreSQL + Redis. Локально без Postgres: DJANGO_USE_SQLITE=true
# DJANGO_USE_SQLITE=true

DEFAULT_STORAGE_QUOTA_BYTES=5368709120

# django-allauth + Яндекс ID — Redirect URI в кабинете Яндекса, например:
#   http://127.0.0.1:8000/accounts/yandex/login/callback/
# localhost и 127.0.0.1 для Яндекса — разные URI; домен в админке «Сайты» = тот же хост:порт без http.
YANDEX_AUTH_CLIENT_ID=your_yandex_oauth_client_id
YANDEX_AUTH_CLIENT_SECRET=your_yandex_oauth_client_secret
YANDEX_DISK_CLIENT_ID=your_yandex_disk_client_id
YANDEX_DISK_CLIENT_SECRET=your_yandex_disk_client_secret
YANDEX_DISK_REDIRECT_URI=http://127.0.0.1:8000/files/oauth/yandex/callback/

EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.yandex.ru
EMAIL_PORT=587
EMAIL_HOST_USER=your_email_login
EMAIL_HOST_PASSWORD=your_app_password
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
EMAIL_TIMEOUT=30
DEFAULT_FROM_EMAIL=noreply@classroom.local
SERVER_EMAIL=noreply@classroom.local

# ConvertAPI (Office→PDF), см. https://www.convertapi.com/
# CONVERTAPI_SECRET=

# ClamAV: в Docker-образе по умолчанию включён (ENV в Dockerfile), freshclam+clamd стартуют в entrypoint от root.
# Отключить: CLAMAV_ENABLED=0. Базы — volume clamav_data (/var/lib/clamav в compose).
# CLAMAV_FAIL_OPEN=1
# CLAMAV_SOCKET_PATH=/var/run/clamav/clamd.ctl

# Раздача /media/ из Django в одном контейнере без nginx (prod за reverse-proxy — по ситуации):
# DJANGO_SERVE_MEDIA=true

# За HTTPS-прокси (prod):
# DJANGO_SECURE_SSL_REDIRECT=true
# DJANGO_SESSION_COOKIE_SECURE=true
# DJANGO_CSRF_COOKIE_SECURE=true
# DJANGO_BEHIND_PROXY=true
